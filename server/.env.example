# Flowforge backend — environment template (blueprint §11).
# Copy to `.env` for local development and fill in real values.
# Every environment value the app reads is listed here with a placeholder —
# never commit real secrets. `__` maps to configuration section nesting.

# PostgreSQL connection string (pooled). Used by the API and `dotnet ef`.
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=flowforge;Username=postgres;Password=postgres

# Allowed CORS origins for the frontend (array via __0, __1, ...).
Cors__AllowedOrigins__0=http://localhost:3000

# JWT access tokens (§4.1). SigningKey must be ≥ 32 bytes of high entropy — rotate periodically.
Jwt__Issuer=flowforge-api
Jwt__Audience=flowforge-client
Jwt__SigningKey=change-me-to-a-random-32+byte-secret-string
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30

# Rate limiting (per IP, per minute). Provisional defaults; finalized in the security pass.
RateLimiting__GlobalPermitPerMinute=100
RateLimiting__AuthPermitPerMinute=10

# Apply EF migrations at startup (dev/compose only — prod uses a migration job, §8).
Database__MigrateOnStartup=true
