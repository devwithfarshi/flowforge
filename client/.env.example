# Flowforge frontend — environment template.
# Copy to `.env.local` for local development. Only NEXT_PUBLIC_* vars reach the
# browser, and they are inlined at BUILD time (`next build`), so set them before
# building for each environment. See node_modules/next/dist/docs → environment-variables.

# Base URL of the Flowforge REST API, including the version prefix (§6.1 → /api/v1).
# The typed fetch wrapper in src/lib/http/ prepends this to every request path.
#   • `dotnet run` (local backend):     http://localhost:5289/api/v1
#   • docker-compose (full-stack E2E):  http://localhost:8080/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:5289/api/v1

# Google Identity Services client ID for the "Continue with Google" button (§4.5).
# Must be the same OAuth 2.0 client id the backend checks as `aud` (Google__ClientId).
# Optional — the button throws a clear error until a real id is set.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
